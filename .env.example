# Firebase 콘솔(https://console.firebase.google.com) > 프로젝트 설정 > 일반 탭에서
# "웹 앱 추가" 후 나오는 firebaseConfig 값을 그대로 옮겨 적으세요.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Authentication > Sign-in method > 이메일/비밀번호를 켜고
# Authentication > Users 탭에서 아래 이메일로 관리자 계정을 하나 만드세요.
# 관리자 페이지에서는 비밀번호만 입력하면 되고, 이메일은 내부적으로만 사용됩니다.
VITE_ADMIN_EMAIL=admin@miku-songbook.local
</content>
