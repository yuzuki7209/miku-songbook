rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 노래 목록: 누구나 읽을 수 있지만, 추가/삭제는 로그인한 관리자만 가능.
    match /songs/{songId} {
      allow read: if true;
      allow update: if false;
      allow delete: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() < 200
        && request.resource.data.sheetUrl is string
        && request.resource.data.sheetUrl.size() < 500
        && request.resource.data.audioUrl is string
        && request.resource.data.audioUrl.size() < 500
        && request.resource.data.proficiency in ['good', 'okay', 'cry'];
    }

    // 노래 요청: 방문자 누구나 남길 수 있고, 삭제(정리)는 관리자만.
    match /requests/{requestId} {
      allow read: if true;
      allow update: if false;
      allow delete: if request.auth != null;
      allow create: if request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() < 200
        && request.resource.data.note is string
        && request.resource.data.note.size() < 500;
    }

    // 감상평: 방문자 누구나 남길 수 있고, 삭제(정리)는 관리자만.
    match /reviews/{reviewId} {
      allow read: if true;
      allow update: if false;
      allow delete: if request.auth != null;
      allow create: if request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() < 30
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() < 500;
    }
  }
}
